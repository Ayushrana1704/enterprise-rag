# =============================================================================
# Enterprise AI Knowledge Assistant -- Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Enterprise AI Knowledge Assistant"

# Options: local | dev | test | staging | prod
APP_ENV=local

APP_DEBUG=false
APP_LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000


# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a strong random secret for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30


# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://enterprise:enterprise123@localhost:5432/enterprise_ai


# -----------------------------------------------------------------------------
# Vector Store (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents

# QDRANT_API_KEY
#   Leave empty for local Qdrant (no authentication required).
#   Set to your Qdrant Cloud API key for cloud deployments.
#   When non-empty, the client connects over HTTPS automatically.
#
#   Local (Docker Compose):  QDRANT_API_KEY=
#   Qdrant Cloud:            QDRANT_API_KEY=your-cloud-api-key
QDRANT_API_KEY=


# -----------------------------------------------------------------------------
# Embedding Model
# -----------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=BAAI/bge-m3


# -----------------------------------------------------------------------------
# LLM Provider
#
# LLM_PROVIDER
#   Informational label used in logs and health-check output.
#   Does not affect request routing -- set the correct LLM_BASE_URL instead.
#   Suggested values: lm_studio | groq
#
# LLM_BASE_URL
#   The base URL of an OpenAI-compatible API, WITHOUT a trailing slash.
#   The service appends "/chat/completions" for generation requests and
#   "/models" for health checks.
#
# LLM_API_KEY
#   Bearer token for authenticated providers.
#   Leave empty (or remove the line) for local providers that require no auth.
#   When non-empty, every request includes:  Authorization: Bearer <value>
#
# LLM_MODEL_NAME
#   Model identifier sent in the request body as the "model" field.
#   Must match a model available at LLM_BASE_URL.
#
# LLM_TEMPERATURE
#   Sampling temperature. 0.0 = deterministic (recommended for RAG).
#
# LLM_REQUEST_TIMEOUT_SECONDS
#   Per-request timeout covering both the sync and streaming paths.
#   Increase for large models or slow hardware.
# -----------------------------------------------------------------------------

# --- Option A: LM Studio (local development) ---------------------------------
# Start LM Studio, load a model, and enable the local server (default port 1234).
# No API key is required.

LLM_PROVIDER=lm_studio
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=
LLM_MODEL_NAME=gemma-3-1b-instruct
LLM_TEMPERATURE=0.0
LLM_REQUEST_TIMEOUT_SECONDS=60


# --- Option B: Groq (production) ---------------------------------------------
# Obtain an API key from https://console.groq.com
# Groq supports llama3-8b-8192, llama3-70b-8192, mixtral-8x7b-32768, and others.
# See https://console.groq.com/docs/models for the current model list.
#
# Uncomment and replace the block above with the lines below:

# LLM_PROVIDER=groq
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL_NAME=llama3-8b-8192
# LLM_TEMPERATURE=0.0
# LLM_REQUEST_TIMEOUT_SECONDS=30


# -----------------------------------------------------------------------------
# Hybrid Search (BM25 + Qdrant)
# -----------------------------------------------------------------------------
HYBRID_SEARCH_ENABLED=true
BM25_CORPUS_PATH=bm25_corpus.json

# Reciprocal Rank Fusion constant. Lower = stronger top-rank preference.
RRF_K=60

# Each retriever fetches (result_limit * this factor